#!/usr/bin/env python3
import argparse
import subprocess
from pathlib import Path
from textwrap import dedent
import sys

DEFAULT_IMAGE = "https://cloud.debian.org/cdimage/cloud/trixie/20260112-2355/debian-13-generic-amd64-20260112-2355.qcow2"


def run(cmd):
    subprocess.check_call(cmd)


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def main():
    p = argparse.ArgumentParser(prog="limaproj")
    sub = p.add_subparsers(dest="cmd", required=True)

    c = sub.add_parser("create", help="Create a per-project Lima VM")
    c.add_argument("name", help="VM name, e.g. proj-foo")
    c.add_argument("--policy", choices=["trusted", "untrusted", "airgap"], default="trusted")
    c.add_argument("--repo", default=None, help="Repo path on host (default: current directory)")
    c.add_argument("--image", default=DEFAULT_IMAGE, help="Cloud image URL (default: Debian 13.3 generic)")
    c.add_argument("--cpus", default="4")
    c.add_argument("--memory", default="6GiB")
    c.add_argument("--disk", default="30GiB")

    s = sub.add_parser("start")
    s.add_argument("name")
    sh = sub.add_parser("shell")
    sh.add_argument("name")
    st = sub.add_parser("stop")
    st.add_argument("name")
    d = sub.add_parser("delete")
    d.add_argument("name")

    args = p.parse_args()

    root = Path.home() / ".lima" / "limaproj"
    templates = root / "templates"
    projects = root / "projects"
    projects.mkdir(parents=True, exist_ok=True)

    if args.cmd == "create":
        name = args.name
        repo = Path(args.repo).expanduser() if args.repo else Path.cwd()
        repo = repo.resolve()

        if not repo.exists():
            print(f"Repo path does not exist: {repo}", file=sys.stderr)
            sys.exit(2)

        proj_dir = projects / name
        proj_dir.mkdir(parents=True, exist_ok=True)
        out_yaml = proj_dir / "lima.yaml"

        base = read_text(templates / "base.yaml")
        policy = read_text(templates / f"{args.policy}.yaml")

        # Compose a final config. We keep it simple: append policy YAML after base.
        # Lima will treat this as one YAML document; to avoid conflicts, base.yaml should be minimal.
        final = (
            dedent(
                f"""\
        # Generated by limaproj
        # name: {name}
        # policy: {args.policy}
        # repo: {repo}

        images:
          - location: \"{args.image}\"
            arch: \"x86_64\"

        cpus: {args.cpus}
        memory: \"{args.memory}\"
        disk: \"{args.disk}\"

        # Mount ONLY the repo for Option A
        mounts:
          - location: \"{repo}\"
            mountPoint: \"/workspace\"
            writable: true

        """
            )
            + "\n# --- base ---\n"
            + base
            + "\n# --- policy ---\n"
            + policy
            + "\n"
        )

        out_yaml.write_text(final, encoding="utf-8")

        # Create VM from file + ensure name
        run(["limactl", "create", "--name", name, str(out_yaml)])
        print(f"Created {name} ({args.policy}) mounting {repo} -> /workspace")
        return

    if args.cmd in ("start", "shell", "stop", "delete"):
        run(["limactl", args.cmd, args.name])
        return


if __name__ == "__main__":
    main()
