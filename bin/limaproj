#!/usr/bin/env python3
import argparse
import subprocess
from pathlib import Path
from textwrap import dedent
import sys
import re
from collections import OrderedDict

DEFAULT_IMAGE = "https://cloud.debian.org/cdimage/cloud/trixie/20260112-2355/debian-13-generic-arm64-20260112-2355.qcow2"


def run(cmd, ignore_missing_instance=False):
    result = subprocess.run(cmd, text=True, capture_output=True)
    if result.returncode == 0:
        return
    if ignore_missing_instance:
        stderr = (result.stderr or "").lower()
        if "non-existent instance" in stderr or "ignoring non-existent instance" in stderr:
            print(result.stderr.strip(), file=sys.stderr)
            return
    if result.stderr:
        print(result.stderr.strip(), file=sys.stderr)
    raise SystemExit(result.returncode)


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


TOP_KEY_RE = re.compile(r"^([A-Za-z0-9_-]+):")


def split_top_level_blocks(text: str) -> OrderedDict:
    lines = text.splitlines(keepends=True)
    starts = []
    keys = []
    for i, line in enumerate(lines):
        if not line or line[0].isspace() or line.lstrip().startswith("#"):
            continue
        m = TOP_KEY_RE.match(line)
        if m:
            starts.append(i)
            keys.append(m.group(1))
    blocks = OrderedDict()
    for idx, start in enumerate(starts):
        end = starts[idx + 1] if idx + 1 < len(starts) else len(lines)
        key = keys[idx]
        blocks[key] = "".join(lines[start:end])
    return blocks


def merge_blocks(base: OrderedDict, override: OrderedDict) -> OrderedDict:
    out = OrderedDict(base)
    for k, v in override.items():
        out[k] = v
    return out


def merge_with_order(base: OrderedDict, policy: OrderedDict, header: OrderedDict) -> str:
    order = []
    for k in base.keys():
        if k not in order:
            order.append(k)
    for k in policy.keys():
        if k not in order:
            order.append(k)
    for k in header.keys():
        if k not in order:
            order.append(k)
    merged = merge_blocks(base, policy)
    merged = merge_blocks(merged, header)
    return "".join(merged[k] for k in order if k in merged)


def main():
    p = argparse.ArgumentParser(prog="limaproj")
    sub = p.add_subparsers(dest="cmd", required=True)

    c = sub.add_parser("create", help="Create a per-project Lima VM")
    c.add_argument("name", help="VM name, e.g. proj-foo")
    c.add_argument("--policy", choices=["trusted", "untrusted", "airgap"], default="trusted")
    c.add_argument("--repo", default=None, help="Repo path on host (default: current directory)")
    c.add_argument("--image", default=DEFAULT_IMAGE, help="Cloud image URL (default: Debian 13.3 generic arm64)")
    c.add_argument("--cpus", default="4")
    c.add_argument("--memory", default="6GiB")
    c.add_argument("--disk", default="30GiB")

    s = sub.add_parser("start")
    s.add_argument("name")
    sh = sub.add_parser("shell")
    sh.add_argument("name")
    st = sub.add_parser("stop")
    st.add_argument("name")
    d = sub.add_parser("delete", help="Delete a VM instance")
    d.add_argument("name")

    args = p.parse_args()

    root = Path.home() / ".lima" / "_config" / "limaproj" / "limaproj"
    templates = root / "templates"
    projects = root / "projects"
    projects.mkdir(parents=True, exist_ok=True)

    if args.cmd == "create":
        name = args.name
        repo = Path(args.repo).expanduser() if args.repo else Path.cwd()
        repo = repo.resolve()

        if not repo.exists():
            print(f"Repo path does not exist: {repo}", file=sys.stderr)
            sys.exit(2)

        proj_dir = projects / name
        proj_dir.mkdir(parents=True, exist_ok=True)
        out_yaml = proj_dir / "lima.yaml"

        instance_dir = Path.home() / ".lima" / name
        if instance_dir.exists():
            print(
                f"Instance '{name}' already exists at {instance_dir}.",
                file=sys.stderr,
            )
            print(
                f"Delete it with: limaproj delete {name} (or limactl delete {name})",
                file=sys.stderr,
            )
            sys.exit(2)

        base = read_text(templates / "base.yaml")
        policy = read_text(templates / f"{args.policy}.yaml")

        header_comment = dedent(
            f"""\
        # Generated by limaproj
        # name: {name}
        # policy: {args.policy}
        # repo: {repo}

        """
        )

        header_body = dedent(
            f"""\
        images:
          - location: "{args.image}"
            arch: "aarch64"

        cpus: {args.cpus}
        memory: "{args.memory}"
        disk: "{args.disk}"

        # Mount ONLY the repo for Option A
        mounts:
          - location: "{repo}"
            mountPoint: "/workspace"
            writable: true
        """
        )

        base_blocks = split_top_level_blocks(base)
        policy_blocks = split_top_level_blocks(policy)
        header_blocks = split_top_level_blocks(header_body)

        final = header_comment + merge_with_order(base_blocks, policy_blocks, header_blocks)

        out_yaml.write_text(final, encoding="utf-8")

        # Create VM from file + ensure name
        run(["limactl", "create", "--name", name, str(out_yaml)])
        print(f"Created {name} ({args.policy}) mounting {repo} -> /workspace")
        return

    if args.cmd in ("start", "shell", "stop", "delete"):
        run(["limactl", args.cmd, args.name], ignore_missing_instance=args.cmd == "delete")
        return


if __name__ == "__main__":
    main()
